{
  "expo": {
    "name": "MangaRabbit",
    "slug": "manga-app",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.tonyalbert5.mangaapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "1939b080-776f-4e0a-a560-06b3e31901a6"
      }
    },
    "plugins": [
      "expo-image",
      "expo-sharing"
    ]
  }
}
